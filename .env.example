PORT=8787

# Shared state for horizontal resolver deployments. When DATABASE_URL is unset,
# the resolver falls back to the local JSON store. REDIS_URL enables distributed
# rate limiting and disables in-process polling in favor of the queue worker.
# DATABASE_URL=postgresql://fiber_offers:change-me@127.0.0.1:54320/fiber_offers
# DATABASE_POOL_MAX=10
# REDIS_URL=redis://127.0.0.1:63790
# REDIS_KEY_PREFIX=fiber-offers
# RESOLVER_QUEUE_NAME=fiber-offers-maintenance

# Optional. Leave unset for open local demo mode.
# RESOLVER_API_KEY=change-me
# Encrypts persisted webhook secrets with AES-256-GCM. Required for hosted deployments.
# RESOLVER_SECRET_ENCRYPTION_KEY=replace-with-a-long-random-secret
# Private/localhost webhook targets default to disabled when NODE_ENV=production.
# RESOLVER_ALLOW_PRIVATE_WEBHOOKS=false
# RESOLVER_RATE_LIMIT_WINDOW_MS=60000
# RESOLVER_RATE_LIMIT_MAX=120

FIBER_INVOICE_MODE=fiber-rpc
FIBER_RPC_URL=http://127.0.0.1:8227
FIBER_RPC_INVOICE_METHOD=new_invoice
FIBER_RPC_GET_INVOICE_METHOD=get_invoice
FIBER_RPC_PROBE_METHOD=node_info

# Docker defaults to a private bridge relay for an FNN bound to host loopback.
# FIBER_RPC_HOST=127.0.0.1
# FIBER_RPC_PORT=8227

# Optional basic auth if your Fiber RPC endpoint requires it.
# FIBER_RPC_USERNAME=
# FIBER_RPC_PASSWORD=
# Equivalent merchant-prefixed aliases are supported:
# MERCHANT_FIBER_RPC_URL=https://fiber-rpc.merchant.example
# MERCHANT_FIBER_RPC_USERNAME=
# MERCHANT_FIBER_RPC_PASSWORD=

# Optional controlled payer-to-merchant topology and E2E test settings.
# RESOLVER_URL=http://127.0.0.1:8787
# MERCHANT_FIBER_RPC_URL=http://127.0.0.1:8227
# PAYER_FIBER_RPC_URL=http://127.0.0.1:8229
# FIBER_E2E_DRY_RUN_ONLY=true
# FIBER_E2E_AMOUNT=1000
# FIBER_E2E_TRAMPOLINE_HOPS=
# FIBER_E2E_MAX_FEE_AMOUNT=100000
# FIBER_E2E_MAX_FEE_RATE=

# Optional standalone payer route check.
# FIBER_INVOICE=fibt1...
# FIBER_ROUTE_TIMEOUT_SECONDS=60
# FIBER_ROUTE_TRAMPOLINE_HOPS=
# FIBER_ROUTE_MAX_FEE_AMOUNT=100000
# FIBER_ROUTE_MAX_FEE_RATE=

# Optional payer-to-merchant topology report.
# FIBER_TOPOLOGY_STRICT=false

# Optional guarded direct-channel fixture.
# The command is report-only unless FIBER_FIXTURE_OPEN_DIRECT_CHANNEL=true.
# FIBER_DIRECT_CHANNEL_FUNDING_AMOUNT=10000000000
# FIBER_MERCHANT_PEER_ADDRESS=/ip4/127.0.0.1/tcp/8228/p2p/...
# FIBER_DIRECT_CHANNEL_PUBLIC=false
# FIBER_DIRECT_CHANNEL_ONE_WAY=false
# FIBER_FIXTURE_OPEN_DIRECT_CHANNEL=false

# Resolver background workers and webhook delivery controls.
RESOLVER_WORKERS_ENABLED=true
RESOLVER_WORKERS_RUN_ON_START=true
# In a Redis deployment, run `npm run worker`; API replicas leave these false.
# RESOLVER_SETTLEMENT_SYNC_INTERVAL_MS=30000
# RESOLVER_WEBHOOK_RETRY_INTERVAL_MS=30000
# RESOLVER_WEBHOOK_MAX_ATTEMPTS=8
# RESOLVER_WEBHOOK_RETRY_MIN_AGE_MS=30000
# RESOLVER_WEBHOOK_TIMEOUT_MS=10000
