{
  "name": "@fiber-offers/sdk",
  "version": "0.1.0",
  "description": "JavaScript SDK for creating, resolving, and paying Nervos Fiber Offers.",
  "license": "MIT",
  "type": "module",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "files": [
    "src"
  ],
  "dependencies": {
    "@fiber-offers/protocol": "0.1.0"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./browser": {
      "types": "./src/browser.d.ts",
      "import": "./src/browser.js",
      "default": "./src/browser.js"
    },
    "./node": {
      "types": "./src/node.d.ts",
      "import": "./src/node.js",
      "default": "./src/node.js"
    },
    "./react": {
      "types": "./src/react.d.ts",
      "import": "./src/react.js",
      "default": "./src/react.js"
    },
    "./react-native": {
      "types": "./src/react-native.d.ts",
      "import": "./src/react-native.js",
      "default": "./src/react-native.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.72"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leothatguy/fiber-offers.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://fiber-offers.leothatguy.me/docs/sdk",
  "bugs": {
    "url": "https://github.com/leothatguy/fiber-offers/issues"
  },
  "keywords": [
    "nervos",
    "ckb",
    "fiber-network",
    "payments",
    "sdk"
  ],
  "publishConfig": {
    "access": "public"
  }
}
